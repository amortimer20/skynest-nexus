          <Code code={Figure3} frame="code" lang="java" title="Figure 3 — Immutability" class="mb-3" />
          <Code code={Figure4} frame="code" lang="java" title="Figure 4 — substring + indexOf pattern" class="mb-3" />

          <hr class="my-4" />

          <h3><span class="text-skynest-theme">Task 1</span>: String Analyzer</h3>
          <Code code={Task1} frame="code" lang="java" title="Task 1 — String Analyzer" />

