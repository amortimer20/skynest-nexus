//#region CodeSnippets

const SlideA = `// Recursion review
// A recursive method has two parts:

// 1. Base case
// The stopping condition

// 2. Recursive case
// The method calls itself with a smaller problem
`;

const SlideB = `// Example
public static int sum(int n)
{
    if (n == 0)
    {
        return 0;
    }

    return n + sum(n - 1);
}
`;

const SlideC = `// What does this return?

sum(4)

= 4 + sum(3)
= 4 + 3 + sum(2)
= 4 + 3 + 2 + sum(1)
= 4 + 3 + 2 + 1 + sum(0)
= 10
`;

const SlideD = `// Key idea
// Each recursive call moves closer
// to the base case.

sum(5)
sum(4)
sum(3)
sum(2)
sum(1)
sum(0)  <-- base case
`;

const Figure1 = `// Figure 1 — Predict the output

public static void mystery(int n)
{
    if (n == 0)
    {
        return;
    }

    System.out.println(n);
    mystery(n - 1);
}
`;

const Figure2 = `// Figure 2 — Predict the return value

public static int mystery(int n)
{
    if (n == 1)
    {
        return 1;
    }

    return n * mystery(n - 1);
}
`;

const Figure3 = `// Figure 3 — Recursive string length

public static int length(String s)
{
    if (s.equals(""))
    {
        return 0;
    }

    return 1 + length(s.substring(1));
}
`;

const Figure4 = `// Figure 4 — Check if array is sorted

public static boolean isSorted(int[] arr, int index)
{
    if (index >= arr.length - 1)
    {
        return true;
    }

    if (arr[index] > arr[index + 1])
    {
        return false;
    }

    return isSorted(arr, index + 1);
}
`;

