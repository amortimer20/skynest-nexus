---
import Presentation from "../../../components/Presentation.astro";
import Divider from "../../../components/ui/Divider.astro";
import Layout from "../../../layouts/Layout.astro";
import { Code } from "astro-expressive-code/components";
import { Code as CodeSnippet } from "astro:components";

//#region CodeSnippets
const SampleOutput = `
SkyNest: Your Benevolent Tech Dictators
1234 Terminator Lane
Lakewood, OH 44107
`;
//#endregion
---

<Layout>
  <div class="container my-4">
    <div class="row justify-content-center">
      <div class="col-sm-12 col-md-10">
        <a href="/courses/foce/" class="btn btn-sm btn-outline-light mb-3">
          <i class="si-arrow-left"></i> Back
        </a>

        <h1>Code Challenge: Mailing Address</h1>

        <h4>
          Difficulty&nbsp;&nbsp;
          <i class="si-star text-sn-green"></i>
        </h4>

        <Divider variant="8" classes="mb-5" />

        <section id="objective">
          <h2>Objective</h2>

          <p>
            Print a fictitious mailing label using formatted console output.
          </p>

          <h4>Skills to Practice</h4>

          <ul>
            <li>Creating and running a program</li>
            <li>Displaying console output</li>
          </ul>
        </section>

        <hr />

        <section id="tasks">
          <h2>Tasks</h2>

          <ul>
            <li>
              Create a new <b>Python</b> program named <b class="text-sn-theme"
                >cc-mail-call.py</b
              >.
            </li>
            <li>
              Think of a fictitious address. Please don't use your real home
              address.
            </li>
            <li>Display the mailing address.</li>
          </ul>
        </section>

        <hr />

        <section id="sample-output">
          <h2>Sample Output</h2>

          <Code
            code={SampleOutput}
            frame="terminal"
            title="Sample Output"
            lang="txt"
            showLineNumbers={false}
            class="mt-3"
          />
        </section>

        <h1
          class="text-center mt-5 text-sn-theme border border-primary slow-flash"
        >
          Commence Challenge
        </h1>
      </div>
    </div>
  </div>
</Layout>
