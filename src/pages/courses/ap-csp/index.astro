---
import Layout from "../../../layouts/Layout.astro";
import ListItem from "../../../components/ui/ListItem.astro";

import ApCspIcon from "../../../assets/courses/ap-csp/img/ap-csp-icon.svg";
---

<Layout>
  <div class="py-5 mb-3 bg-sn-darker bottom-shadow">
    <div class="p-5">
      <a href="/#course-content" class="btn btn-sm btn-outline-light"
        ><i class="si-arrow-left"></i> Back</a
      >
    </div>
    <div class="container pb-5">
      <div class="text-center">
        <h1>AP Computer Science Principles</h1>
        <ApCspIcon width={128} height={128} />
      </div>
    </div>
  </div>

  <div class="container">
    <h3>Course Content</h3>
    <div class="accordion mb-5" id="courseAccordion">
      <!-- Quarter 1 -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#flush-collapseOne"
            aria-expanded="true"
            aria-controls="flush-collapseOne"
          >
            Quarter 1: Foundations + Programming Fundamentals
          </button>
        </h2>
        <div
          id="flush-collapseOne"
          class="accordion-collapse collapse"
          data-bs-parent="#courseAccordion"
        >
          <div class="accordion-body">
            <h6 class="text-sn-theme mt-2">Week 1: Welcome &amp; Setup</h6>
            <ListItem><a href="./1-1">Activity 1.1: Computer Systems</a></ListItem>
            <ListItem><a href="./1-2">Activity 1.2: Welcome to AP CSP</a></ListItem>
            <ListItem><a href="./1-3">Activity 1.3: Variables and Console Output</a></ListItem>

            <h6 class="text-sn-theme mt-3">Week 2: Data Types, Operators &amp; Expressions</h6>
            <ListItem><a href="./1-4">Activity 1.4: Arithmetic Operations</a></ListItem>
            <ListItem><a href="./1-5">Activity 1.5: Updating Variables</a></ListItem>
            <ListItem><a href="./1-6">Activity 1.6: String Interpolation</a></ListItem>
            <ListItem><a href="./1-7">Activity 1.7: Console Input</a></ListItem>
            <ListItem><a href="./1-8">Activity 1.8: Numeric Input</a></ListItem>
          </div>
        </div>
      </div>
      <!-- Quarter 2 -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#flush-collapseTwo"
            aria-expanded="false"
            aria-controls="flush-collapseTwo"
          >
            Quarter 2: Abstraction, Lists &amp; Transition to Graphics
          </button>
        </h2>
        <div
          id="flush-collapseTwo"
          class="accordion-collapse collapse"
          data-bs-parent="#courseAccordion"
        >
          <div class="accordion-body">
            <ListItem><a href="./TBD">TBD</a></ListItem>
          </div>
        </div>
      </div>
      <!-- Quarter 3 -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#flush-collapseThree"
            aria-expanded="false"
            aria-controls="flush-collapseThree"
          >
            Quarter 3: Create Performance Task
          </button>
        </h2>
        <div
          id="flush-collapseThree"
          class="accordion-collapse collapse"
          data-bs-parent="#courseAccordion"
        >
          <div class="accordion-body">
            <ListItem><a href="./TBD">TBD</a></ListItem>
          </div>
        </div>
      </div>
      <!-- Quarter 4 -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#flush-collapseFour"
            aria-expanded="false"
            aria-controls="flush-collapseFour"
          >
            Quarter 4: Close Content &amp; Exam Prep
          </button>
        </h2>
        <div
          id="flush-collapseFour"
          class="accordion-collapse collapse"
          data-bs-parent="#courseAccordion"
        >
          <div class="accordion-body">
            <ListItem><a href="./TBD">TBD</a></ListItem>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
