---
import Layout from "../../../layouts/Layout.astro";
import ListItem from "../../../components/ui/ListItem.astro";

import GameDesignIcon from "../../../assets/courses/game-design/img/game-design-icon.svg";
---

<Layout>
  <div class="py-5 mb-3 bg-sn-darker bottom-shadow">
    <div class="p-5">
      <a href="/#course-content" class="btn btn-sm btn-outline-light"
        ><i class="si-arrow-left"></i> Back</a
      >
    </div>
    <div class="container pb-5">
      <div class="text-center">
        <h1>Fundamentals of Game Design</h1>
        <GameDesignIcon width={128} height={128} />
      </div>
    </div>
  </div>

  <div class="container">
    <h3>Course Content</h3>
    <div class="accordion mb-5" id="courseAccordion">
      <!-- Quarter 1 -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#flush-collapseOne"
            aria-expanded="true"
            aria-controls="flush-collapseOne"
          >
            Quarter 1: Foundations &amp; Physics
          </button>
        </h2>
        <div
          id="flush-collapseOne"
          class="accordion-collapse collapse"
          data-bs-parent="#courseAccordion"
        >
          <div class="accordion-body">
            <h6 class="text-sn-theme mt-2">Week 1: Concepts + Setup</h6>
            <ListItem><a href="./1-1">Activity 1.1: Getting Started with Godot</a></ListItem>
            <ListItem><a href="./1-2">Activity 1.2: Transforms and Your First Scene</a></ListItem>

            <h6 class="text-sn-theme mt-3">Week 2: Nodes, Scenes &amp; the Scene Tree</h6>
            <ListItem><a href="./2-1">Activity 2.1: Building a Scene from Nodes</a></ListItem>
            <ListItem><a href="./2-2">Activity 2.2: The Scene Tree, Coordinate Space, and Draw Order</a></ListItem>
          </div>
        </div>
      </div>
      <!-- Quarter 2 -->
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#flush-collapseTwo"
            aria-expanded="false"
            aria-controls="flush-collapseTwo"
          >
            Quarter 2: Systems, Events &amp; a Full Game
          </button>
        </h2>
        <div
          id="flush-collapseTwo"
          class="accordion-collapse collapse"
          data-bs-parent="#courseAccordion"
        >
          <div class="accordion-body">
            <ListItem><a href="./TBD">TBD</a></ListItem>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
