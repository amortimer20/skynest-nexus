---
import Presentation from "../../../components/Presentation.astro";
import Divider from "../../../components/ui/Divider.astro";
import Layout from "../../../layouts/Layout.astro";
import { Code } from "astro-expressive-code/components";
import { Code as CodeSnippet } from "astro:components";

import ReactionCircuitImg from "../../../assets/courses/tech-ed-electronics/img/reaction-circuit.png";

//#region CodeSnippets
const ProjectCode = `int waitTime;
int startTime;
int reactTime;

void setup() {
  Serial.begin(9600);
  pinMode(13, OUTPUT);
  pinMode(12, OUTPUT);
  pinMode(11, OUTPUT);
  pinMode(3, INPUT);
}

void loop() {
  Serial.println("When the LED turns on, push the button!");
  Serial.println("Now, watch the LED. Ready?");
  waitTime = random(2000, 4000); //random wait time 
  delay(waitTime);  //delay random wait time
  digitalWrite(13, HIGH);    

  startTime = millis();  //set zero time reference

  //loop to wait until button is pressed
  while(digitalRead(3) == HIGH) { }

  reactTime = millis() - startTime; //calculation of reaction time
  
  digitalWrite(13, LOW);  //turn off LED!

  if (reactTime <= 215) {
    digitalWrite(12, HIGH);  //green LED ON
    digitalWrite(11, LOW);   //red LED OFF
  }
  else {
    digitalWrite(12, LOW);   //green LED OFF
    digitalWrite(11, HIGH);  //red LED ON
  }
  
  //display results 
  Serial.print("Nice job! Your reaction time was ");
  Serial.print(reactTime);
  Serial.println(" milliseconds");

  //short delay before starting again
  delay(5000);
  digitalWrite(12, LOW);
  digitalWrite(11, LOW);
}`;
//#endregion
---

<Layout>
  <div class="container my-4">
    <div class="row justify-content-center">
      <div class="col-sm-12 col-md-10">
        <a href="/courses/tech-ed-electronics/" class="btn btn-sm btn-outline-light mb-3">
          <i class="si-arrow-left"></i> Back
        </a>

        <h1>Project 3 Reaction Game</h1>
        <Divider variant="8" classes="mb-5" />

        <section>
          <h2>Task 1: Circuit</h2>
          <span>Required components:</span>
          <ul>
            <li>(3) LEDs</li>
            <li>(3) 330 ohm resistors</li>
            <li>(1) 10k ohm resistor</li>
            <li>(1) push button</li>
          </ul>

          <img
            src={ReactionCircuitImg.src}
            alt="Reaction Game Circuit"
            class="img-fluid rounded d-block mx-auto"
          />

          <hr class="my-4" />

          <h3>Task 2: Code</h3>

          <Code code={ProjectCode} frame="code" lang="cpp" title="reaction_game.ino" />
        </section>

        <Divider variant="8" classes="my-5" />

        <section id="submit">
          <h1
            class="text-center mt-5 text-sn-theme border border-primary slow-flash"
          >
            Project Complete
          </h1>
        </section>
      </div>
    </div>
  </div>
</Layout>
