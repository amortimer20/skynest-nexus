---
import Presentation from "../../../components/Presentation.astro";
import Divider from "../../../components/ui/Divider.astro";
import Layout from "../../../layouts/Layout.astro";
import { Code } from "astro-expressive-code/components";
import { Code as CodeSnippet } from "astro:components";

import AnimationCircuitImg from "../../../assets/courses/tech-ed-electronics/img/animation-circuit.png";

//#region CodeSnippets
const ProjectCode = `int led1 = 13;
int led2 = 12;
int led3 = 11;
int led4 = 10;
int led5 = 9;
int led6 = 8;
int led7 = 7;
int led8 = 6;
int led9 = 5;
int delayTime = 500;

void setup() {
  pinMode(led1, OUTPUT);
  pinMode(led2, OUTPUT);
  pinMode(led3, OUTPUT);
  pinMode(led4, OUTPUT);
  pinMode(led5, OUTPUT);
  pinMode(led6, OUTPUT);
  pinMode(led7, OUTPUT);
  pinMode(led8, OUTPUT);
  pinMode(led9, OUTPUT);
}

void loop() {
  // Sample animation - Blink every row

  // Row 1
  digitalWrite(led1, HIGH);
  digitalWrite(led2, HIGH);
  digitalWrite(led3, HIGH);
  delay(delayTime);
  digitalWrite(led1, LOW);
  digitalWrite(led2, LOW);
  digitalWrite(led3, LOW);

  // Row 2
  digitalWrite(led4, HIGH);
  digitalWrite(led5, HIGH);
  digitalWrite(led6, HIGH);
  delay(delayTime);
  digitalWrite(led4, LOW);
  digitalWrite(led5, LOW);
  digitalWrite(led6, LOW);
  
  // Row 3
  digitalWrite(led7, HIGH);
  digitalWrite(led8, HIGH);
  digitalWrite(led9, HIGH);
  delay(delayTime);
  digitalWrite(led7, LOW);
  digitalWrite(led8, LOW);
  digitalWrite(led9, LOW);
}`;
//#endregion
---

<Layout>
  <div class="container my-4">
    <div class="row justify-content-center">
      <div class="col-sm-12 col-md-10">
        <a href="./" class="btn btn-sm btn-outline-light mb-3">
          <i class="si-arrow-left"></i> Back
        </a>

        <h1>Project 2 Animation Machine</h1>
        <Divider variant="8" classes="mb-5" />

        <section>
          <h2>Task 1: Circuit</h2>
          <span>Required components:</span>
          <ul>
            <li>(9) LEDs</li>
            <li>(9) 330 ohm resistors</li>
          </ul>

          <img
            src={AnimationCircuitImg.src}
            alt="Animation Machine circuit"
            class="img-fluid rounded d-block mx-auto"
          />

          <hr class="my-4" />

          <h3>Task 2: Code</h3>

          <Code code={ProjectCode} frame="code" lang="cpp" title="animation_machine.ino" />
        </section>

        <Divider variant="8" classes="my-5" />

        <section id="submit">
          <h1
            class="text-center mt-5 text-sn-theme border border-primary slow-flash"
          >
            Project Complete
          </h1>
        </section>
      </div>
    </div>
  </div>
</Layout>
