---
import Divider from "../../../components/ui/Divider.astro";
import Layout from "../../../layouts/Layout.astro";
---

<Layout>
  <div class="container my-4">
    <div class="row justify-content-center">
      <div class="col-sm-12 col-md-10">
        <a
          href="/courses/course-title/unit-title/"
          class="btn btn-sm btn-outline-light mb-3"
        >
          <i class="si-arrow-left"></i> Back
        </a>

        <h1>Group Project X: Project Title</h1>
        <Divider variant="8" classes="mb-5" />

        <!-- Overview -->
        <section id="overview">
          <h2>Overview</h2>

          <p>INSERT the premise — what students are building and why.</p>

          <h4>Requirements</h4>
          <ul>
            <li></li>
            <li></li>
          </ul>

          <h4>Groups</h4>
          <ul>
            <li>Group size: INSERT&ndash;INSERT students</li>
            <li>Formation deadline: INSERT</li>
          </ul>
        </section>

        <Divider variant="8" classes="my-5" />

        <!--
          Milestones
          One row per class-time checkpoint across the project window
          (pitch -> build days -> playtest -> showcase). This replaces the
          single-sitting Task list from the activity templates, since a
          capstone spans multiple weeks rather than one class period.
        -->
        <section id="milestones">
          <h2>Milestones</h2>

          <div class="table-responsive">
            <table class="table table-dark table-bordered align-middle">
              <thead>
                <tr>
                  <th>Week</th>
                  <th>Milestone</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>INSERT</td>
                  <td>Pitch</td>
                  <td></td>
                </tr>
                <tr>
                  <td>INSERT</td>
                  <td>Build</td>
                  <td></td>
                </tr>
                <tr>
                  <td>INSERT</td>
                  <td>Playtest</td>
                  <td></td>
                </tr>
                <tr>
                  <td>INSERT</td>
                  <td>Showcase</td>
                  <td></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <Divider variant="8" classes="my-5" />

        <!-- Rubric -->
        <section id="rubric">
          <h2>Rubric</h2>

          <div class="table-responsive">
            <table class="table table-dark table-bordered align-middle">
              <thead>
                <tr>
                  <th>Criteria</th>
                  <th>Weight</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Functionality</td>
                  <td>INSERT%</td>
                  <td></td>
                </tr>
                <tr>
                  <td>Concept Application</td>
                  <td>INSERT%</td>
                  <td></td>
                </tr>
                <tr>
                  <td>Polish &amp; Game Feel</td>
                  <td>INSERT%</td>
                  <td></td>
                </tr>
                <tr>
                  <td>Individual Contribution</td>
                  <td>INSERT%</td>
                  <td></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <Divider variant="8" classes="my-5" />

        <!-- Submit -->
        <section id="submit">
          <h2>Submit</h2>

          <p>
            Export a native Windows build and submit it to the appropriate
            dropbox for showcase on the arcade cabinet.
          </p>

          <h1
            class="text-center mt-5 text-sn-theme border border-primary slow-flash"
          >
            Ready for Showcase
          </h1>
        </section>
      </div>
    </div>
  </div>
</Layout>
